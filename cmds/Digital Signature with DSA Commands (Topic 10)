# --- RSA Digital Signature Workflow ---

# 1. Generate RSA private key
openssl genpkey -algorithm RSA -out keyfile.pem -aes256

# 2. Extract RSA public key
openssl rsa -in keyfile.pem -pubout -out public_key.pem

# 3. Attempt to sign before file exists (error shown)
openssl dgst -sha256 -sign keyfile.pem -out file1.txt.sha256.sig file1.txt

# 4. Create a plaintext file
echo "Hello" > file1.txt

# 5. Sign the file using RSA private key
openssl dgst -sha256 -sign keyfile.pem -out file1.txt.sha256.sig file1.txt

# 6. Verify the signature using RSA public key
openssl dgst -sha256 -verify public_key.pem -signature file1.txt.sha256.sig file1.txt


# --- DSA Digital Signature Workflow ---

# 7. Generate DSA parameters (2048-bit)
openssl dsaparam -out dsaparam.pem 2048

# 8. Generate DSA private key
openssl gendsa -out private_dsa.pem dsaparam.pem

# 9. Extract DSA public key
openssl dsa -in private_dsa.pem -pubout -out public_dsa.pem

# 10. Attempt to sign non-existent file (error shown)
openssl dgst -sha256 -sign private_dsa.pem -out signature.bin message.txt

# 11. Create a message file (note typo: mesaage.txt)
echo "Harshal Is a devops engineer. got 15 lpa as fresher. believe in urself." > mesaage.txt

# 12. Sign the message using DSA private key
openssl dgst -sha256 -sign private_dsa.pem -out signature.bin mesaage.txt

# 13. View the message file content
cat mesaage.txt

# 14. Verify the signature using DSA public key
openssl dgst -sha256 -verify public_dsa.pem -signature signature.bin mesaage.txt

