🔐 Symmetric Key Exchange (Passwords)

# Person1 creates script and encrypts for Person2
echo 'echo "Hello"' > script1.sh
openssl enc -aes-256-cbc -pbkdf2 -in script1.sh -out enc1.bin -pass pass:person1-person2

# Person2 decrypts, edits, and encrypts for Person3
openssl enc -aes-256-cbc -pbkdf2 -d -in enc1.bin -out script1.sh -pass pass:person1-person2
echo 'echo "cdac"' >> script1.sh
openssl enc -aes-256-cbc -pbkdf2 -in script1.sh -out enc2.bin -pass pass:person2-person3

# Person3 decrypts, edits, and encrypts for Person1
openssl enc -aes-256-cbc -pbkdf2 -d -in enc2.bin -out script2.sh -pass pass:person2-person3
echo 'echo "ditiss"' >> script2.sh
openssl enc -aes-256-cbc -pbkdf2 -in script2.sh -out enc3.bin -pass pass:person1-person3

# Person1 decrypts final script and runs it
openssl enc -aes-256-cbc -pbkdf2 -d -in enc3.bin -out final_script.sh -pass pass:person1-person3
bash final_script.sh

